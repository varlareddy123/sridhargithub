{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "SRIDHARADF0462"
		},
		"AzureSqlDatabase1_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'AzureSqlDatabase1'"
		},
		"HttpServer1_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'HttpServer1'"
		},
		"sridharLS_sink_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'sridharLS_sink'"
		},
		"sridharadlssin_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'sridharadlssin'"
		},
		"sridharsourcelin_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'sridharsourcelin'"
		},
		"AzureSqlDatabase1_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sridhardbserver.database.windows.net"
		},
		"AzureSqlDatabase1_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "DB-sridhar"
		},
		"AzureSqlDatabase1_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sqladmin"
		},
		"HttpServer1_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://github.com/varlareddy123/sridhargithub/blob/main/RAW/Sirdhar_practice_data_cleaning.csv"
		},
		"HttpServer1_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": " varlareddy123"
		},
		"sridharLS_sink_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sridhardbserver.database.windows.net"
		},
		"sridharLS_sink_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "DB-sridhar"
		},
		"sridharLS_sink_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sqladmin"
		},
		"sridharadlssin_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://sridharstg.dfs.core.windows.net/"
		},
		"sridharsourcelin_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://raw.githubusercontent.com"
		},
		"sridharsourcelin_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "varlareddy123"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "SRIDHARADF0462_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureSqlDatabase1_password": {
						"value": "[parameters('AzureSqlDatabase1_password')]"
					},
					"HttpServer1_password": {
						"value": "[parameters('HttpServer1_password')]"
					},
					"sridharLS_sink_password": {
						"value": "[parameters('sridharLS_sink_password')]"
					},
					"sridharadlssin_accountKey": {
						"value": "[parameters('sridharadlssin_accountKey')]"
					},
					"sridharsourcelin_password": {
						"value": "[parameters('sridharsourcelin_password')]"
					},
					"AzureSqlDatabase1_properties_typeProperties_server": {
						"value": "[parameters('AzureSqlDatabase1_properties_typeProperties_server')]"
					},
					"AzureSqlDatabase1_properties_typeProperties_database": {
						"value": "[parameters('AzureSqlDatabase1_properties_typeProperties_database')]"
					},
					"AzureSqlDatabase1_properties_typeProperties_userName": {
						"value": "[parameters('AzureSqlDatabase1_properties_typeProperties_userName')]"
					},
					"HttpServer1_properties_typeProperties_url": {
						"value": "[parameters('HttpServer1_properties_typeProperties_url')]"
					},
					"HttpServer1_properties_typeProperties_userName": {
						"value": "[parameters('HttpServer1_properties_typeProperties_userName')]"
					},
					"sridharLS_sink_properties_typeProperties_server": {
						"value": "[parameters('sridharLS_sink_properties_typeProperties_server')]"
					},
					"sridharLS_sink_properties_typeProperties_database": {
						"value": "[parameters('sridharLS_sink_properties_typeProperties_database')]"
					},
					"sridharLS_sink_properties_typeProperties_userName": {
						"value": "[parameters('sridharLS_sink_properties_typeProperties_userName')]"
					},
					"sridharadlssin_properties_typeProperties_url": {
						"value": "[parameters('sridharadlssin_properties_typeProperties_url')]"
					},
					"sridharsourcelin_properties_typeProperties_url": {
						"value": "[parameters('sridharsourcelin_properties_typeProperties_url')]"
					},
					"sridharsourcelin_properties_typeProperties_userName": {
						"value": "[parameters('sridharsourcelin_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}